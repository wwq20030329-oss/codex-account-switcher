def print_current_profile_usage_json() -> int:
    profiles = list_profiles()
    state = load_state()
    info = current_account_info()
    active_name = find_matching_profile_name(info, profiles, state)
    if not active_name:
        return print_json(None)

    profile = next((item for item in profiles if item["profile_name"] == active_name), None)
    if not profile:
        return print_json(None)

    usage = fetch_profile_usage(profile)
    return print_json(
        {
            **profile,
            "active": True,
            "usage": usage,
            "usage_summary": usage_summary_text(usage),
        }
    )


def print_usage() -> int:
    payload = fetch_codex_usage_payload()
    print("当前 Codex 用量")
    print(f"  邮箱: {payload.get('email') or '未知'}")
    print(f"  套餐: {payload.get('plan_display') or '未知'}")
    print(f"  来源: {payload.get('source')}")
    print(f"  {format_window_summary('5 小时窗口', payload.get('primary_window'))}")
    print(f"  {format_window_summary('每周窗口', payload.get('secondary_window'))}")
    credits = payload.get("credits") or {}
    if credits.get("unlimited"):
        print("  Credits: unlimited")
    elif credits.get("has_credits"):
        print(f"  Credits: {credits.get('balance')}")
    else:
        print("  Credits: 无额外 credits")
    return 0


def print_usage_json() -> int:
    return print_json(fetch_codex_usage_payload())


def is_codex_running() -> bool:
    result = subprocess.run(
        ["osascript", "-e", 'application "Codex" is running'],
        capture_output=True,
        text=True,
        check=False,
    )
    return result.stdout.strip().lower() == "true"


def quit_codex_if_needed() -> bool:
    was_running = is_codex_running()
    if not was_running:
        return False

    subprocess.run(["osascript", "-e", 'tell application "Codex" to quit'], check=False)
    deadline = time.time() + 20
    while time.time() < deadline:
        if not is_codex_running():
            return True
        time.sleep(0.5)

    subprocess.run(["pkill", "-x", "Codex"], check=False)
    deadline = time.time() + 5
    while time.time() < deadline:
        if not is_codex_running():
            return True
        time.sleep(0.5)

    raise SwitcherError("没能自动关闭 Codex，请先手动退出后再重试。")


def reopen_codex() -> None:
    subprocess.run(["open", "-a", "Codex"], check=False)


def snapshot_current_profile(name: str, *, force: bool = False) -> dict[str, Any]:
    info = current_account_info()
    if not info:
        raise SwitcherError("没有检测到当前登录态，无法保存。")

    target_dir = profile_dir(name)
    existing = load_json(target_dir / "profile.json", {})
    if existing and not force and not metadata_matches_account(existing, info):
        raise SwitcherError(
            f"档案 {name} 已绑定到另一个账号。若要强制覆盖，请重试并加上 --force。"
        )

    created_at = existing.get("created_at") or now_iso()
    temp_root = Path(tempfile.mkdtemp(prefix="profile-", dir=SWITCHER_HOME))
    try:
        snapshot_root = temp_root / sanitize_name(name)
        snapshot_root.mkdir(parents=True, exist_ok=True)

        for item in SNAPSHOT_ITEMS:
            if not item.live_path.exists():
                if item.required:
                    raise SwitcherError(f"缺少必要文件：{item.live_path}")
                continue
            copy_path(item.live_path, snapshot_root / item.snapshot_rel)

        metadata = {
            "profile_name": sanitize_name(name),
            "created_at": created_at,
            "updated_at": now_iso(),
            **info,
        }
        write_json(snapshot_root / "profile.json", metadata)

        if target_dir.exists():
            shutil.rmtree(target_dir)
        os.replace(snapshot_root, target_dir)
        return metadata
    finally:
        if temp_root.exists():
            shutil.rmtree(temp_root, ignore_errors=True)


def restore_profile(name: str) -> dict[str, Any]:
    metadata = read_profile(name)
    source_root = profile_dir(name)

    for item in SNAPSHOT_ITEMS:
        live_path = item.live_path
        snapshot_path = source_root / item.snapshot_rel
        remove_path(live_path)
        if snapshot_path.exists():
            copy_path(snapshot_path, live_path)

    return metadata


def auto_save_current_account_if_needed() -> dict[str, Any] | None:
    profiles = list_profiles()
    state = load_state()
    info = current_account_info()
    if not info:
        return None

    matched_name = find_matching_profile_name(info, profiles, state)
    if matched_name:
        if state.get("active_profile") != matched_name:
            state["active_profile"] = matched_name
            save_state(state)
        return None

    existing_names = {profile["profile_name"] for profile in profiles}
    target_name = default_profile_name(info, existing_names)
    metadata = snapshot_current_profile(target_name, force=False)

    state["active_profile"] = target_name
    state["last_auto_saved_at"] = now_iso()
    state["last_auto_saved_profile"] = target_name
    save_state(state)
    return metadata


def save_command(name: str | None, force: bool) -> int:
    profiles = list_profiles()
    state = load_state()
    info = current_account_info()
    if not info:
        raise SwitcherError("当前没有登录 Codex，无法保存账号档案。")

    existing_names = {profile["profile_name"] for profile in profiles}
    matched_name = find_matching_profile_name(info, profiles, state)
    target_name = sanitize_name(name) if name else matched_name or default_profile_name(
        info, existing_names
    )

    was_running = quit_codex_if_needed()
    metadata = snapshot_current_profile(target_name, force=force)

    state["active_profile"] = target_name
    state["last_saved_at"] = now_iso()
    save_state(state)

    if was_running:
        reopen_codex()

    account = metadata.get("email") or metadata.get("name") or metadata.get("account_id") or "未知账号"
    print(f"已保存档案 {target_name} -> {account}")
    return 0


def ensure_current_saved_command() -> int:
    metadata = auto_save_current_account_if_needed()
    if not metadata:
        return 0
    account = metadata.get("email") or metadata.get("name") or metadata.get("account_id") or "未知账号"
    print(f"已自动保存新账号档案 {metadata['profile_name']} -> {account}")
    return 0


def switch_command(name: str) -> int:
    target_name = sanitize_name(name)
    read_profile(target_name)

    profiles = list_profiles()
    state = load_state()
    info = current_account_info()
    current_profile_name = find_matching_profile_name(info, profiles, state)

    if current_profile_name == target_name:
        print(f"当前已经是档案 {target_name}。")
        if not is_codex_running():
            reopen_codex()
        return 0

    save_before_switch_name: str | None = None
    if info and current_profile_name is None:
        action = choose_unmanaged_account_action()
        if action in {None, "取消"}:
            return 0
        if action == "先保存再切换":
            default_name = (
                info.get("email")
                or info.get("name")
                or info.get("account_id")
                or "当前账号"
            )
            profile_name = prompt_for_profile_name(default_name)
            if not profile_name:
                return 0
            save_before_switch_name = sanitize_name(profile_name)
        elif action != "直接切换":
            return 0

    was_running = quit_codex_if_needed()

    if save_before_switch_name:
        snapshot_current_profile(save_before_switch_name, force=False)
    elif current_profile_name:
        snapshot_current_profile(current_profile_name, force=False)

    restored = restore_profile(target_name)

    state["active_profile"] = target_name
    if save_before_switch_name:
        state["last_saved_profile"] = save_before_switch_name
    state["last_switched_at"] = now_iso()
    save_state(state)

    reopen_codex()
    account = restored.get("email") or restored.get("name") or restored.get("account_id") or "未知账号"
    suffix = "，Codex 已重新打开。" if was_running else "，你现在可以直接使用。"
    print(f"已切换到档案 {target_name} -> {account}{suffix}")
    return 0


def delete_command(name: str) -> int:
    target_name = sanitize_name(name)
    target_dir = profile_dir(target_name)
    if not target_dir.exists():
        raise SwitcherError(f"找不到档案：{target_name}")

    shutil.rmtree(target_dir)
    state = load_state()
    if state.get("active_profile") == target_name:
        state.pop("active_profile", None)
        save_state(state)

    print(f"已删除档案 {target_name}")
    return 0


def rename_command(old_name: str, new_name: str) -> int:
    source_name = sanitize_name(old_name)
    target_name = sanitize_name(new_name)
    if source_name == target_name:
        print(f"档案名未变化：{source_name}")
        return 0

    source_dir = profile_dir(source_name)
    target_dir = profile_dir(target_name)
    if not source_dir.exists():
        raise SwitcherError(f"找不到档案：{source_name}")
    if target_dir.exists():
        raise SwitcherError(f"档案名已存在：{target_name}")

    metadata = read_profile(source_name)
    metadata["profile_name"] = target_name
    metadata["updated_at"] = now_iso()
    write_json(source_dir / "profile.json", metadata)
    os.replace(source_dir, target_dir)

    state = load_state()
    if state.get("active_profile") == source_name:
        state["active_profile"] = target_name
    if state.get("last_saved_profile") == source_name:
        state["last_saved_profile"] = target_name
    save_state(state)

    account = metadata.get("email") or metadata.get("name") or metadata.get("account_id") or "未知账号"
    print(f"已重命名档案 {source_name} -> {target_name} ({account})")
    return 0


def choose_profile_via_gui(profiles: list[dict[str, Any]], active_name: str | None) -> str | None:
    if not profiles:
        show_alert("还没有任何已保存档案。先点“保存当前账号”，再来切换。")
        return None

    profiles_with_usage = (
        profiles
        if profiles and all("usage_summary" in profile for profile in profiles)
        else enrich_profiles_with_usage(profiles)
    )
    labels = []
    mapping: dict[str, str] = {}
    for profile in profiles_with_usage:
        account = profile.get("email") or profile.get("name") or profile.get("account_id") or "未知账号"
        marker = "当前" if profile["profile_name"] == active_name else "可切换"
        usage_summary = profile.get("usage_summary") or "额度未知"
        label = f"{profile['profile_name']} | {account} | {marker} | {usage_summary}"
        labels.append(label)
        mapping[label] = profile["profile_name"]

    script = """
    on run argv
      tell application "System Events" to activate
      set selected to choose from list argv with prompt "选择要切换的 Codex 账号" OK button name "切换" cancel button name "取消" without multiple selections allowed
      if selected is false then
        return ""
      end if
      return item 1 of selected
    end run
    """
    result = subprocess.run(
        ["osascript", "-e", script, *labels],
        capture_output=True,
        text=True,
        check=False,
    )
    selected = result.stdout.strip()
    if not selected:
        return None
    return mapping.get(selected)


def save_current_account_via_gui() -> int:
    info = current_account_info()
    if not info:
        show_alert("当前没有检测到 Codex 登录态，无法保存。请先登录一个账号。")
        return 0

    profiles = list_profiles()
    state = load_state()
    matched_name = find_matching_profile_name(info, profiles, state)
    default_name = (
        matched_name
        or info.get("email")
        or info.get("name")
        or info.get("account_id")
        or "当前账号"
    )
    message = "给当前登录的 Codex 账号起个名字。若之前已保存同一账号，会自动更新对应档案。"
    profile_name = prompt_for_profile_name(default_name, message)
    if not profile_name:
        return 0
    return save_command(profile_name, force=False)


def rename_profile_via_gui(profiles: list[dict[str, Any]], active_name: str | None) -> int:
    selected_name = choose_profile_via_gui(profiles, active_name)
    if not selected_name:
        return 0

    metadata = read_profile(selected_name)
    default_name = metadata.get("profile_name") or selected_name
    account = metadata.get("email") or metadata.get("name") or metadata.get("account_id") or "这个账号"
    message = f"给档案“{selected_name}”改个新名字。\\n对应账号：{account}"
    target_name = prompt_for_profile_name(default_name, message)
    if not target_name:
        return 0
    return rename_command(selected_name, target_name)


def menu_command() -> int:
    auto_save_current_account_if_needed()
    info = current_account_info()
    profiles = list_profiles()
    state = load_state()
    active_name = find_matching_profile_name(info, profiles, state)
    action = choose_main_action(info, profiles, active_name)
    if not action or action == "取消":
        return 0
    if action == "保存当前账号":
        return save_current_account_via_gui()
    if action == "重命名档案":
        return rename_profile_via_gui(profiles, active_name)
    if action == "查看套餐/额度":
        enriched_profiles = []
        for profile in enrich_profiles_with_usage(profiles):
            enriched_profiles.append(
                {
                    **profile,
                    "active": profile["profile_name"] == active_name,
                }
            )
        show_profiles_usage_alert(enriched_profiles)
        return 0
    if action == "切换其它账号":
        selected_name = choose_profile_via_gui(profiles, active_name)
        if not selected_name:
            return 0
        return switch_command(selected_name)
    return 0


def doctor_command() -> int:
    print("Codex 账号切换器环境检查")
    for item in SNAPSHOT_ITEMS:
        status = "存在" if item.live_path.exists() else "缺失"
        required = "必需" if item.required else "可选"
        print(f"  [{required}] {item.live_path} -> {status}")
    print(f"  配置目录: {SWITCHER_HOME}")
    return 0


def default_backup_path() -> Path:
    timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    return HOME / "Desktop" / f"codex-account-switcher-backup-{timestamp}.zip"


def export_backup_command(output_path: str | None) -> int:
    profiles = list_profiles()
    target = Path(output_path).expanduser() if output_path else default_backup_path()
    if target.suffix.lower() != ".zip":
        target = target.with_suffix(".zip")
    target.parent.mkdir(parents=True, exist_ok=True)

    with zipfile.ZipFile(target, "w", compression=zipfile.ZIP_DEFLATED) as archive:
        if STATE_FILE.exists():
            archive.write(STATE_FILE, arcname="state.json")
        if PROFILES_DIR.exists():
            for path in sorted(PROFILES_DIR.rglob("*")):
                if path.is_dir():
                    continue
                archive.write(path, arcname=str(Path("profiles") / path.relative_to(PROFILES_DIR)))

        manifest = {
            "exported_at": now_iso(),
            "profile_count": len(profiles),
            "profiles": [profile.get("profile_name") for profile in profiles],
        }
        archive.writestr("manifest.json", json.dumps(manifest, ensure_ascii=False, indent=2) + "\n")

    print(f"已导出 {len(profiles)} 个档案到 {target}")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="codex-account-switcher",
        description="保存多个 Codex 登录态，并通过档案快速切换。",
    )
    subparsers = parser.add_subparsers(dest="command")

    save_parser = subparsers.add_parser("save", help="保存当前登录态为一个档案")
    save_parser.add_argument("name", nargs="?", help="档案名，不传则自动生成")
    save_parser.add_argument("--force", action="store_true", help="允许强制覆盖同名档案")

    subparsers.add_parser("list", aliases=["ls"], help="列出已保存档案")
    subparsers.add_parser("current", help="显示当前登录账号")
    subparsers.add_parser("profiles-json", help="以 JSON 输出已保存档案")
    subparsers.add_parser("profiles-usage-json", help="以 JSON 输出已保存档案及各自的 Codex 额度")
    subparsers.add_parser("profiles-usage-cached-json", help="以 JSON 输出已保存档案及缓存额度，适合快速展示")
    subparsers.add_parser("current-profile-usage-json", help="以 JSON 输出当前档案及其实时 Codex 额度")
    subparsers.add_parser("current-json", help="以 JSON 输出当前登录账号")
    subparsers.add_parser("usage", help="显示当前 Codex 用量")
    subparsers.add_parser("usage-json", help="以 JSON 输出当前 Codex 用量")
    subparsers.add_parser("ensure-current-saved", help="自动保存当前未纳入管理的新账号")
    export_parser = subparsers.add_parser("export-backup", aliases=["backup"], help="导出所有档案为 zip 备份")
    export_parser.add_argument("output_path", nargs="?", help="备份 zip 输出路径，不传则默认导出到桌面")

    switch_parser = subparsers.add_parser("switch", help="切换到指定档案")
    switch_parser.add_argument("name", help="要切换到的档案名")

    rename_parser = subparsers.add_parser("rename", help="重命名一个档案")
    rename_parser.add_argument("old_name", help="原档案名")
    rename_parser.add_argument("new_name", help="新档案名")

    menu_parser = subparsers.add_parser("menu", help="弹出原生选择框并切换")
    menu_parser.description = "弹出原生 macOS 列表，选择后切换并重启 Codex。"

    delete_parser = subparsers.add_parser("delete", help="删除一个档案")
    delete_parser.add_argument("name", help="要删除的档案名")

    subparsers.add_parser("doctor", help="检查本机所需文件是否存在")
    return parser


class FileLock:
    def __init__(self, path: Path) -> None:
        self.path = path
        self.handle: Any = None

    def __enter__(self) -> "FileLock":
        ensure_layout()
        self.handle = self.path.open("w", encoding="utf-8")
        fcntl.flock(self.handle.fileno(), fcntl.LOCK_EX)
        return self

    def __exit__(self, exc_type: Any, exc: Any, tb: Any) -> None:
        if self.handle is None:
            return
        fcntl.flock(self.handle.fileno(), fcntl.LOCK_UN)
        self.handle.close()


def main(argv: list[str] | None = None) -> int:
    ensure_layout()
    parser = build_parser()
    args = parser.parse_args(argv)

    command = args.command or "menu"
    with FileLock(LOCK_FILE):
        if command == "save":
            return save_command(args.name, args.force)
        if command in {"list", "ls"}:
            return print_profiles()
        if command == "current":
            return print_current_account()
        if command == "profiles-json":
            return print_profiles_json()
        if command == "profiles-usage-json":
            return print_profiles_usage_json()
        if command == "profiles-usage-cached-json":
            return print_profiles_usage_cached_json()
        if command == "current-profile-usage-json":
            return print_current_profile_usage_json()
        if command == "current-json":
            return print_current_account_json()
        if command == "usage":
            return print_usage()
        if command == "usage-json":
            return print_usage_json()
        if command == "ensure-current-saved":
            return ensure_current_saved_command()
        if command in {"export-backup", "backup"}:
            return export_backup_command(args.output_path)
        if command == "switch":
            return switch_command(args.name)
        if command == "rename":
            return rename_command(args.old_name, args.new_name)
        if command == "menu":
            return menu_command()
        if command == "delete":
            return delete_command(args.name)
        if command == "doctor":
            return doctor_command()

    parser.print_help()
    return 1


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except SwitcherError as error:
        print(f"错误: {error}", file=sys.stderr)
        raise SystemExit(1)
