def print_profiles() -> int:
    profiles = list_profiles()
    state = load_state()
    active_name = find_matching_profile_name(current_account_info(), profiles, state)

    if not profiles:
        print("还没有保存任何 Codex 账号档案。")
        print("先登录一个账号，然后运行: codex-account-switcher save 你的名称")
        return 0

    profiles = enrich_profiles_with_usage(profiles)
    print(f"已保存 {len(profiles)} 个 Codex 账号档案")
    print("  档案名                     账号                                     登录方式      最近保存 | 套餐/额度")
    for profile in profiles:
        print(format_profile_line(profile, active_name))
    return 0


